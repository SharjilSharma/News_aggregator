# NeuroPulse — Environment Variables Template
# Copy this file to .env and fill in your values

# Google Gemini API Key (free tier: 1500 req/day, 1M tokens/day)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# YouTube Data API v3 (optional — leave blank to skip YouTube cards)
# Get yours at: https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=

# DB path override (useful for cloud deployments with persistent disk)
# DB_PATH=/data/news.db
